# Hostinger provides these automatically
COMPOSE_PROJECT_NAME=teamie-scraper
TRAEFIK_HOST=your-hostinger-domain.com
TZ=Europe/London

# Teamie scraper settings
TEAMIE_URL=https://lms.asl.org/dash/#/
GOOGLE_EMAIL=your_email@asl.org
TEAMIE_USER_ID=your_user_id
HEADLESS=false
LOG_LEVEL=INFO
USE_PERSISTENT_SESSION=true
TIMEOUT=60000
